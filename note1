*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Arial;
background:#111114;
color:white;
overflow:hidden;
}

.home{
display:flex;
height:100vh;
}

.left{
width:30%;
background:#e6e6e6;
color:#333;
padding:80px 40px;
}

.left h1{
font-size:60px;
margin-bottom:20px;
}

.panels{
display:flex;
flex:1;
overflow:hidden;
}

.panel{
position:relative;
flex:1;
transform:skewX(-15deg);
overflow:hidden;
cursor:pointer;
transition:0.5s;
}

.panel img{
width:130%;
height:100%;
object-fit:cover;
transform:skewX(15deg) scale(1.2);
transition:0.5s;
}

.panel:hover{
flex:1.5;
}

.panel:hover img{
transform:skewX(15deg) scale(1.3);
}

.text{
position:absolute;
bottom:40px;
left:40px;
font-size:20px;
transform:skewX(15deg);
}
